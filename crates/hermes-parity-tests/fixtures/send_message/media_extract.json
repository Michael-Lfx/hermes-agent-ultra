{
  "schema_version": 1,
  "fixture_group": "send_message",
  "python_module": "gateway/platforms/base.py::extract_media",
  "cases": [
    {
      "id": "strips_media_tag",
      "op": "extract_media",
      "input": {
        "content": "Hello\nMEDIA:/workspace/photo.png\nWorld"
      },
      "expected": {
        "media": [["/workspace/photo.png", false]],
        "cleaned": "Hello\n\nWorld"
      }
    },
    {
      "id": "audio_as_voice_flag",
      "op": "extract_media",
      "input": {
        "content": "[[audio_as_voice]]\nMEDIA:/workspace/voice.ogg"
      },
      "expected": {
        "media": [["/workspace/voice.ogg", true]],
        "cleaned": ""
      }
    }
  ]
}
